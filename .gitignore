# Data files (do not commit raw data)
data/raw/
*.dta
*.sav
*.xlsx
*.csv

# Processed data (can be regenerated)
data/processed/*.rds
data/processed/*.csv

# Model objects (large files)
outputs/models/*.rds
outputs/models/*.json

# Environment files
.Rproj.user
.Rhistory
.RData
.Ruserdata
renv/library/
renv/staging/
renv/.lock

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
*.so
.env
.venv
env/
venv/
ENV/
.eggs/
*.egg-info/
.installed.cfg
*.egg

# Jupyter
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Output files (regeneratable)
outputs/figures/*.png
outputs/figures/*.pdf
outputs/tables/*.csv
outputs/tables/*.html
*.html

# Temporary files
*.tmp
*.temp
*.log

# Compressed files (keep original zips in repo root if needed)
# Uncomment if you want to track the original data zips
# !*.zip

# Claude Code settings
.claude/
